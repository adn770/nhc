#!/usr/bin/env bash
# NHC web server launcher — creates venv, installs deps, and runs the server.
# Usage: ./server [args...]
#   e.g. ./server --host 0.0.0.0 --port 5005 --auth
#        ./server --reset          # ignore autosave, start new game
#        ./server --restart        # kill running server and start fresh

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
REQUIREMENTS="$SCRIPT_DIR/requirements.txt"
ENTRY="$SCRIPT_DIR/nhc_web.py"
PIDFILE="$SCRIPT_DIR/.server.pid"

# ── Restart: kill existing server ──
if [[ "${1:-}" == "--restart" ]]; then
    shift
    if [ -f "$PIDFILE" ]; then
        OLD_PID=$(cat "$PIDFILE")
        if kill -0 "$OLD_PID" 2>/dev/null; then
            echo "Stopping server (PID $OLD_PID)..."
            kill "$OLD_PID" 2>/dev/null || true
            sleep 1
            # Force kill if still running
            kill -0 "$OLD_PID" 2>/dev/null && kill -9 "$OLD_PID" 2>/dev/null
        fi
        rm -f "$PIDFILE"
    else
        # Try to find by port
        PID=$(lsof -ti:5005 2>/dev/null || true)
        if [ -n "$PID" ]; then
            echo "Stopping server on port 5005 (PID $PID)..."
            kill "$PID" 2>/dev/null || true
            sleep 1
        fi
    fi
    echo "Restarting..."
fi

# Create venv if missing
if [ ! -d "$VENV_DIR" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$VENV_DIR"
fi

# Install/update dependencies if requirements.txt is newer than the marker
MARKER="$VENV_DIR/.deps_installed"
if [ ! -f "$MARKER" ] || [ "$REQUIREMENTS" -nt "$MARKER" ]; then
    echo "Installing dependencies..."
    "$VENV_DIR/bin/pip" install --quiet --upgrade pip
    "$VENV_DIR/bin/pip" install --quiet -r "$REQUIREMENTS"
    touch "$MARKER"
fi

# Record PID and run the web server
echo $$ > "$PIDFILE"
trap 'rm -f "$PIDFILE"' EXIT
exec "$VENV_DIR/bin/python" "$ENTRY" "$@"
