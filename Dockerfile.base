FROM python:3.14-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl gcc libc6-dev \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash -u 1000 nhc

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir \
    flask flask-sock shapely gunicorn pyyaml

# TTS support (optional — fails gracefully if unavailable)
RUN pip install --no-cache-dir piper-tts onnxruntime requests || true

RUN apt-get purge -y --auto-remove gcc libc6-dev
